# Google OAuth (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=      # generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000   # set to your Vercel domain in production

# The ONLY email allowed to sign in as admin
ADMIN_EMAIL=banghozin@gmail.com

# Database (Vercel Postgres / Supabase / Neon — any Postgres connection string)
DATABASE_URL=

# Vercel Blob (image uploads) — created automatically when you add the
# Blob storage integration in your Vercel project settings
BLOB_READ_WRITE_TOKEN=
